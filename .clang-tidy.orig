CheckOptions:
  misc-include-cleaner.MissingIncludes: 'false'
  misc-include-cleaner.IgnoreHeaders: 'boost/test/unit_test.hpp;'
  readability-identifier-naming.ClassCase: 'CamelCase'
  readability-identifier-naming.FunctionCase: 'camelBack'
  readability-identifier-naming.MacroDefinitionCase: 'UPPER_CASE'
  readability-identifier-naming.MemberCase: 'camelBack'
  readability-identifier-naming.PrivateMemberPrefix: '_'
  readability-identifier-naming.ProtectedMemberPrefix: '_'
  readability-identifier-naming.PublicMemberPrefix: ''
