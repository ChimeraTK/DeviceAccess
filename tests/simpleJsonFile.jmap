{
  "_comment": "Any unknown keys will be ignored. By convention, comments shall use keys starting with an underscore.",
  "_blubb": "This is also a comment",
  "foo": "This is ignored as well, but shouldn't be used for comments",
  "mapFormatVersion": "0.0.1",
  "metadata": {
    "_comment": "Suggested naming convention: camelcase for property names",
    "mapfileRevivsion": "1.8.3-0-gdeadbeef"
  },
  "interrupts": [
    {
      "0": {
        "INTC": {
          "path": "DAQ",
          "version": 1,
          "_comment": "This is exactly the current JSON snippet from the metadata"
        }
      },
      "3": {
        "INTC": {
          "path": "TEST3",
          "options": [
            "MER"
          ],
          "version": 1
        }
      },
      "3.0": {
        "INTC": {
          "path": "TEST3.SUB0"
        },
        "options": []
      },
      "3.1": {
        "INTC": {
          "path": "TEST3.SUB1",
          "options": [
            "MER"
          ]
        }
      }
    }
  ],
  "addressSpace": [
    {
      "name": "SomeTopLevelRegister",
      "engineeringUnits": "mV",
      "description": "This is an example register",
      "access": "RO",
      "nrOfElements": 1,
      "bytesPerElement": 4,
      "address": {
        "type": "I/O",
        "channel": 0,
        "offset": 32,
        "_comment": "'type' can be 'I/O' (default), or 'DMA'. 'channel' is optional and defaults to 0."
      },
      "representation": {
        "type": "fixedPoint",
        "width": 32,
        "fractionalBits": 0,
        "signed": true,
        "_comment": "type might be fixedPoint (default), IEEE754, bitField, or string"
      }
    },
    {
      "name": "BSP",
      "address": {
        "channel": 0,
        "offset": 0
      },
      "nrOfElements": 19201,
      "bytesPerElement": 4,
      "_comment": "omitting 'representation': width = 8*bytesPerElement, unsigned integer",
      "_comment2": "This is the equivalent of 'ch0_top.BSP', with the BSP.* registers defined as 'children'",
      "children": [
        {
          "name": "VERSION",
          "access": "RO",
          "nrOfElements": 1,
          "bytesPerElement": 4,
          "address": {
            "channel": 0,
            "offset": 4
          },
          "representation": {
            "type": "fixedPoint",
            "width": 32,
            "fractionalBits": 0,
            "signed": false
          },
          "constant": "0x01080300",
          "_comment": "Defining 'constant' value allows to identify/verify firmware version (an type with BSP.PRJ_ID)"
        }
      ]
    },
    {
      "name": "APP",
      "children": [
        {
          "name": "STATUS",
          "description": "application status",
          "access": "RO",
          "address": {
            "type": "I/O",
            "channel": 2,
            "offset": "0x8000"
          },
          "bytesPerElement": 1,
          "representation": {
            "type": "bitField",
            "width": 32,
            "elements": [
              {
                "name": "ProbeLimiter",
                "bitShift": 0,
                "representation": {
                  "width": 1
                }
              },
              {
                "name": "ExternalInterlock",
                "bitShift": 1,
                "representation": {
                  "width": 1
                }
              },
              {
                "name": "ErrorCounter",
                "bitShift": 2,
                "representation": {
                  "type": "fixedPoint",
                  "width": 3,
                  "fractionalBits": 0,
                  "signed": false
                },
                "_comment": "Will initially be unsupported(?)"
              }
            ]
          }
        },
        {
          "name": "SomeTable",
          "access": "RW",
          "numberOfElements": 16384,
          "bytesPerElement": 2,
          "address": {
            "channel": 0,
            "offset": 2048
          },
          "representation": {
            "type": "fixedPoint",
            "width": 18,
            "fractionalBits": 10,
            "signed": true
          }
        }
      ]
    },
    {
      "name": "DAQ",
      "children": [
        {
          "name": "CTRL",
          "description": "Controller DAQ",
          "triggeredByInterrupt": "0",
          "_": "^^^ this implies 'access: RO', do not specify both",
          "nrOfElements": 16384,
          "pitch": 64,
          "_comment": "pitch is the number of bytes between two elements in the same channel",
          "address": {
            "type": "DMA",
            "offset": "0x80000000"
          },
          "doubleBuffering": {
            "secondaryBufferAddress": {
              "type": "DMA",
              "offset": "0x80200000"
            },
            "enableRegister": "DAQ.DOUBLE_BUF.ENA",
            "readBufferRegister": "DAQ.DOUBLE_BUF.INACTIVE_BUF_ID"
          },
          "channels": [
            {
              "name": "errorI",
              "bytesPerElement": 2,
              "offset": 0,
              "description": "Error signal in I",
              "engineeringUnits": "bits",
              "representation": {
                "type": "fixedPoint",
                "width": 16,
                "fractionalBits": -2,
                "signed": true
              }
            },
            {
              "name": "errorQ",
              "bytesPerElement": 2,
              "offset": 2,
              "description": "Error signal in Q",
              "engineeringUnits": "bits",
              "representation": {
                "type": "fixedPoint",
                "width": 16,
                "fractionalBits": -2,
                "signed": true
              }
            },
            {
              "name": "status",
              "bytesPerElement": 4,
              "offset": 4,
              "representation": {
                "type": "bitField",
                "width": 32,
                "elements": [
                  {
                    "name": "ProbeLimiter",
                    "bitShift": 0,
                    "representation": {
                      "width": 1
                    }
                  },
                  {
                    "name": "ExternalInterlock",
                    "bitShift": 1,
                    "representation": {
                      "width": 1
                    }
                  },
                  {
                    "name": "ErrorCounter",
                    "bitShift": 2,
                    "representation": {
                      "type": "fixedPoint",
                      "width": 3,
                      "fractionalBits": 0,
                      "signed": false
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "name": "DOUBLE_BUF",
          "children": [
            {
              "name": "ENA",
              "bytesPerElement": 4,
              "address": {
                "channel": 0,
                "offset": 1234
              },
              "representation": {
                "width": 1
              }
            },
            {
              "name": "INACTIVE_BUF_ID",
              "bytesPerElement": 4,
              "address": {
                "channel": 0,
                "offset": 1238
              },
              "representation": {
                "width": 1
              }
            }
          ]
        }
      ]
    }
  ]
}
